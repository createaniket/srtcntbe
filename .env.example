# Copy to .env and fill in. NEVER commit .env.
PORT=4000
NODE_ENV=development

# Mongo Atlas — rotate the password you shared earlier!
MONGODB_URI=mongodb+srv://USER:ROTATED_PASSWORD@cluster-host/jankaam?retryWrites=true&w=majority

# JWT
JWT_SECRET=replace-with-a-long-random-string-min-32-chars
JWT_EXPIRES_IN=7d

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,https://surat-connect-assist.lovable.app

# Trust proxy (set to 1 when behind Render/Railway/Fly/Nginx so req.ip works)
TRUST_PROXY=1
